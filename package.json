{
  "name": "draft-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:sos": "node scripts/generate-sos-data.mjs",
    "aggregate:sos-premier": "node scripts/aggregate-sos-premier-picks.mjs",
    "generate:sos-pick": "node scripts/generate-sos-pick-data.mjs",
    "generate:sos-seed-sql": "node scripts/generate-sos-premier-seed-sql.mjs",
    "seed:sos-premier": "node scripts/seed-sos-premier-picks.mjs",
    "prebuild": "node scripts/generate-sos-data.mjs && node scripts/generate-sos-pick-data.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
